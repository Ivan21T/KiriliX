функция празно главна() {
    цяло а = 10;
    цяло б = 3;
    
    печатай(а + б);
    печатай(а - б);
    печатай(а * б);
    печатай(а / б);
    печатай(а % б);
    
    печатай(а > б);
    печатай(а < б);
    печатай(а == 10);
    печатай(б != 3);
    
    булево в = вярно;
    булево г = грешно;
    
    печатай(в && г);
    печатай(в || г);
    
    върни нищо;
}
