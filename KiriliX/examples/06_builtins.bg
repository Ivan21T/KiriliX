функция празно главна() {
    цяло[] масив = нов_масив(3);
    печатай(дължина(масив));
    
    текст дума = "Тест";
    печатай(дължина(дума));
    
    печатай(корен(25.0));
    печатай(степен(2.0, 4.0));
    
    печатай(към_цяло("100") + 50);
    печатай(към_текст(123) + " е текст");
    
    върни нищо;
}
