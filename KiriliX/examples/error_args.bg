// Тест за извикване на функция с грешен брой аргументи

функция празно поздрави(текст име, цяло години) {
    печатай("Здравей " + име + ", ти си на " + към_текст(години));
    върни нищо;
}

функция празно главна() {
    печатай("Опит за извикване на функция с 1 аргумент вместо 2...");
    
    // Очаква 2 аргумента: текст, цяло. Ние подаваме само 1.
    поздрави("Иван");
    
    върни нищо;
}
