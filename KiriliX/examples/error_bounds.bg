// Тест за излизане извън позволените граници на масив

функция празно главна() {
    цяло списък = [10, 20, 30];
    
    печатай("Нашият масив има 3 елемента.");
    печатай("Опит да достъпим 5-ти елемент (индекс 4)...");
    
    цяло грешка = списък[4]; // Това ще предизвика спиране на програмата
    
    печатай(грешка);
    върни нищо;
}
