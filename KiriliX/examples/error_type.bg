// Тест за подаване на грешен тип данни при логическо условие

функция празно главна() {
    печатай("Очакваме условието в 'ако' да бъде БУЛЕВО (вярно/грешно).");
    
    цяло число = 5;
    
    // В C това минава (5 е истина), но нашият типизиран език търси изрично булево
    ако (число) {
        печатай("Това няма да се отпечата.");
    } иначе {
        печатай("Нито това.");
    }
    
    върни нищо;
}
