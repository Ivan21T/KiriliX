// Този скрипт тества поведение при достъпване на несъществуваща променлива

функция празно главна() {
    печатай("Този код ще крашне, защото достъпва недефинирана променлива.");
    
    цяло а = 5;
    
    // 'б' никога не е дефинирана
    цяло резултат = а + б; 
    
    печатай(резултат);
    върни нищо;
}
