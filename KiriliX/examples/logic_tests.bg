// Логически операции, сравнения и условия

функция празно главна() {
    печатай("=== Сравнения ===");

    цяло х = 10;
    цяло у = 20;

    печатай("10 == 20 ?");
    печатай(х == у);

    печатай("10 != 20 ?");
    печатай(х != у);

    печатай("10 < 20 ?");
    печатай(х < у);

    печатай("10 >= 20 ?");
    печатай(х >= у);

    печатай("=== Логически Оператори ===");
    
    булево истина = вярно;
    булево лъжа = грешно;

    печатай("вярно И вярно (&&):");
    печатай(истина && истина);

    печатай("вярно И грешно (&&):");
    печатай(истина && лъжа);

    печатай("вярно ИЛИ грешно (||):");
    печатай(истина || лъжа);

    печатай("=== Вложени Условия ===");
    
    ако (х < у && истина) {
        печатай("Първото условие е изпълнено!");
        ако (х == 10) {
            печатай("Вложеното условие също!");
        } иначе {
            печатай("Грешка във вложеното условие.");
        }
    } иначе {
        печатай("Условието се провали.");
    }

    върни нищо;
}
