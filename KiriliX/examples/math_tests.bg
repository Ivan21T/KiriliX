// Тестове за математически операции и приоритет

функция празно главна() {
    печатай("=== Математически Операции ===");

    цяло а = 10;
    цяло б = 3;
    дробно в = 2.5;

    печатай("Събиране (10 + 3):");
    печатай(а + б);

    печатай("Изваждане (10 - 3):");
    печатай(а - б);

    печатай("Умножение (10 * 3):");
    печатай(а * б);

    печатай("Деление (10 / 3) [целочислено]:");
    печатай(а / б);

    печатай("Модул (10 % 3):");
    печатай(а % б);

    печатай("Смесено деление (10 / 2.5):");
    печатай(а / в);

    печатай("Приоритет на операции (10 + 3 * 2.5):");
    печатай(а + б * в);

    печатай("Скоби ((10 + 3) * 2.5):");
    печатай((а + б) * в);

    печатай("=== Вградени Математически Функции ===");
    печатай("Корен квадратен(25):");
    печатай(корен(25));
    
    печатай("Корен квадратен(2):");
    печатай(корен(2));

    печатай("Степенуване (2 ^ 8):");
    печатай(степен(2, 8));

    върни нищо;
}
