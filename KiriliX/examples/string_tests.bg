// Тестове за работа с текст и конкатенация

функция празно главна() {
    печатай("=== Текстови Операции ===");

    текст поздрав = "Здравейте, ";
    текст име = "Програмисти!";
    
    печатай("Конкатенация на стрингове:");
    текст резултат = поздрав + име;
    печатай(резултат);

    печатай("Смесване на текст и числа:");
    цяло възраст = 2026;
    печатай("Годината е: " + към_текст(възраст));

    дробно пи = 3.14159;
    печатай("Стойността на Пи е приблизително: " + към_текст(пи));

    булево факт = вярно;
    печатай("Земята е кръгла? " + към_текст(факт));

    върни нищо;
}
