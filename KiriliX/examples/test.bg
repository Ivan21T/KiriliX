// Тестов файл за BgLangC

функция празно главна() {
    // 1. Тест за печат и базови типове
    печатай("=== Тест: Базови типове ===");
    цяло а = 5;
    дробно б = 3.14;
    текст в = "Здравей";
    булево г = вярно;
    
    печатай(а);
    печатай(б);
    печатай(в);
    печатай(г);
    
    // 2. Тест за математика и конкатенация
    печатай("=== Тест: Операции ===");
    печатай(а + б); // Смесен тип
    печатай(в + ", свят!"); // Конкатенация
    
    // 3. Тест за цикли и условия
    печатай("=== Тест: Цикъл ЗА и АКО ===");
    за (цяло и = 0; и < 5; и = и + 1) {
        ако (и % 2 == 0) {
            печатай("Четно: " + към_текст(и));
        } иначе {
            печатай("Нечетно: " + към_текст(и));
        }
    }
    
    // 4. Тест за масиви
    печатай("=== Тест: Масиви ===");
    // Забележка: Типизацията на променливата за масив не е специфицирана.
    // Ще ползваме 'празно' като динамичен тип (тъй като езикът е динамичен вътрешно, 
    // но парсъра изисква тип при декларация). Нека използваме 'текст' или 'цяло', 
    // интерпертаторът позволява пренаписване на типа. 
    цяло масив = [10, 20, 30, 40]; 
    печатай(масив);
    печатай("Дължина на масива: " + към_текст(дължина(масив)));
    печатай("Елемент 1 е: " + към_текст(масив[1]));
    
    масив[1] = 99;
    печатай("След промяна: ");
    печатай(масив);
    
    // 5. Тест за вградени функции
    печатай("=== Тест: Вградени функции ===");
    печатай("Корен от 16: " + към_текст(корен(16)));
    печатай("2 на степен 3: " + към_текст(степен(2, 3)));
    
    // 6. Тест за рекурсия
    печатай("=== Тест: Рекурсия (Фибоначи) ===");
    печатай("Фибоначи(6): " + към_текст(фибоначи(6)));
    
    върни нищо;
}

функция цяло фибоначи(цяло н) {
    ако (н <= 1) {
        върни н;
    }
    върни фибоначи(н - 1) + фибоначи(н - 2);
}
