
функция празно тест_строги_типове() {
    печатай("--- ТЕСТ: Строги Типове ---");
    цяло число = 100;
    число = 200; // Позволено, защото е цяло
    печатай("Число е: " + към_текст(число));

    дробно пи = 3.14;
    пи = 2.71; 
    печатай("Пи е: " + към_текст(пи));

    символ буква = 'A';
    буква = '\n'; 
    печатай("Буквата работи. Приключваме теста за строги типове.");
    върни нищо;
}

функция празно тест_динамични_типове() {
    печатай("--- ТЕСТ: Динамични Типове ('динамично') ---");
    динамично променлива = 10;
    печатай("Сега е число: " + към_текст(променлива));
    променлива = "вече е текст";
    печатай("Сега е текст: " + променлива);
    променлива = [1, 2, 3];
    печатай("Накрая е масив:");
    печатай(променлива);
    върни нищо;
}

функция празно тест_условия() {
    печатай("--- ТЕСТ: Условия и Вложени Условия ---");
    цяло х = 10;
    цяло у = 20;

    ако (х < у) {
        печатай("х е по-малко от у - УСПЕХ!");
        ако (х == 10) {
            печатай("х е точно 10 - ВЛОЖЕН УСПЕХ!");
        } иначе {
            печатай("ГРЕШКА");
        }
    } иначе {
        печатай("ГРЕШКА: х трябва да е под у");
    }

    ако (х > 100) {
        печатай("ГРЕШКА");
    } иначе {
        ако (у == 20) {
            печатай("Сложно вложено иначе - УСПЕХ!");
        }
    }
    върни нищо;
}

функция празно тест_математика() {
    печатай("--- ТЕСТ: Математика ---");
    цяло a = 5;
    цяло b = 3;
    печатай("5 + 3 = " + към_текст(a + b));
    печатай("5 - 3 = " + към_текст(a - b));
    печатай("5 * 3 = " + към_текст(a * b));
    печатай("10 / 2 = " + към_текст(10 / 2));
    печатай("10 % 3 = " + към_текст(10 % 3));

    печатай("Корен от 16: " + към_текст(корен(16)));
    печатай("2 на степен 3: " + към_текст(степен(2, 3)));
    
    дробно д1 = 5.5;
    дробно д2 = 2.0;
    печатай("5.5 * 2.0 = " + към_текст(д1 * д2));
    върни нищо;
}

функция празно тест_логика() {
    печатай("--- ТЕСТ: Логика и Сравнения ---");
    булево истина = вярно;
    булево лъжа = грешно;

    ако (истина && вярно) { печатай("&& работи"); }
    ако (истина || лъжа) { печатай("|| работи"); }
    ако (лъжа && истина) { печатай("ГРЕШКА в && късо-съединение"); }
    ако (лъжа == грешно) { печатай("== за булеви работи"); }
    ако (10 >= 5 && 5 <= 10) { печатай(">= и <= работят"); }
    ако (10 != 5) { печатай("!= работи"); }
    върни нищо;
}

функция празно тест_масиви() {
    печатай("--- ТЕСТ: Масиви и манипулация ---");
    цяло[] масив_числа = [1, 2, 3, 4, 5];
    печатай("Дължина: " + към_текст(дължина(масив_числа))); // 5
    
    печатай("Първоначален масив:");
    печатай(масив_числа);
    
    масив_числа[0] = 99;
    масив_числа[4] = 88;
    печатай("Променен масив:");
    печатай(масив_числа);
    
    текст[] думи = ["едно", "две"];
    печатай("Текстов масив:");
    печатай(думи);
    
    цяло[] празен = нов_масив(5);
    празен[0] = 100;
    печатай("Масив чрез нов_масив(5):");
    печатай(празен);
    
    динамично вложен = [ [1, 2], [3, 4] ];
    печатай("Сложен вложен масив:");
    печатай(вложен);
    върни нищо;
}

функция празно тест_цикли() {
    печатай("--- ТЕСТ: Цикли ---");
    печатай("Цикъл ДОКАТО (While):");
    цяло i = 0;
    докато (i < 3) {
        печатай("i: " + към_текст(i));
        i = i + 1;
    }

    печатай("Цикъл ЗА (For):");
    за (цяло j = 0; j < 3; j = j + 1) {
        печатай("j: " + към_текст(j * 10));
    }
    върни нищо;
}

функция цяло фибоначи(цяло n) {
    ако (n <= 1) {
        върни n;
    }
    върни фибоначи(n - 1) + фибоначи(n - 2);
}

функция празно тест_рекурсия() {
    печатай("--- ТЕСТ: Рекурсия (Фибоначи) ---");
    начало();
    цяло резултат = фибоначи(25); 
    дробно изминало = край();
    печатай("Фибоначи от 25 е: " + към_текст(резултат)); 
    печатай("Време за 25-тото число на Фибоначи: " + към_текст(изминало) + " секунди");
    върни нищо;
}

функция празно главна() {
    тест_строги_типове();
    печатай("=================");
    тест_динамични_типове();
    печатай("=================");
    тест_условия();
    печатай("=================");
    тест_математика();
    печатай("=================");
    тест_логика();
    печатай("=================");
    тест_масиви();
    печатай("=================");
    тест_цикли();
    печатай("=================");
    тест_рекурсия();
    
    печатай("----------------------------------------");
    
    върни нищо;
}
