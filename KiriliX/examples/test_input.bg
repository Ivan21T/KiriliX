печатай "==== ТЕСТ НА ВХОД И ПРЕОБРАЗУВАНЕ ===="

печатай "Въведи някакво цяло число:"
текст текст_цяло = вход()
цяло ч = към_цяло(текст_цяло)
печатай "Ти въведе:"
печатай ч
печатай "По 2 е равно на:"
печатай ч * 2

печатай "----------------"
печатай "Въведи дробно число (напр. 3.14):"
дробно д = към_дробно(вход())
печатай "Ти въведе:"
печатай д
печатай "Плюс 1.5 е равно на:"
печатай д + 1.5

печатай "----------------"
печатай "Въведи някакъв текст (дума):"
символ с = към_символ(вход())
печатай "Първият символ на текста е:"
печатай с

печатай "==== Край на теста ===="
