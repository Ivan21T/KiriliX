функция празно главна() {
    цяло а = 42;
    дробно б = 3.14;
    текст в = "Здравей";
    булево г = вярно;
    символ д = 'A';
    динамично е = 10;
    
    печатай(а);
    печатай(б);
    печатай(в);
    печатай(г);
    печатай(д);
    печатай(е);
    
    е = "Вече съм текст";
    печатай(е);
    
    върни нищо;
}
