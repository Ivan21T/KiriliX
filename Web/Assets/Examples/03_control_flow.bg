функция празно главна() {
    цяло възраст = 18;
    
    ако (възраст >= 18) {
        печатай("Пълнолетен");
    } иначе {
        печатай("Непълнолетен");
    }
    
    цяло брояч = 0;
    докато (брояч < 3) {
        печатай(брояч);
        брояч = брояч + 1;
    }
    
    за (цяло и = 0; и < 3; и = и + 1) {
        печатай(и * 10);
    }
    
    върни нищо;
}
